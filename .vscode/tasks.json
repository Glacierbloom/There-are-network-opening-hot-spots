{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe 生成活动文件",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/nologo",
                "/Fe${fileDirname}\\bin\\${fileBasenameNoExtension}.exe",
                "${file}",
                "/link",
                "windowsapp.lib",
                "ole32.lib",
                "oleaut32.lib"
            ],
            "options": {
                "cwd": "${fileDirname}\\bin"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}